<Window x:Class="HangMan.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HangMan - Game"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="New Game" Command="{Binding NewGameCommand}" />
                <MenuItem Header="Open Game" Command="{Binding OpenGameCommand}" />
                <MenuItem Header="Save Game" Command="{Binding SaveGameCommand}" />
                <Separator/>
                <MenuItem Header="Statistics" Command="{Binding StatisticsCommand}" />
                <MenuItem Header="Cancel" Command="{Binding CancelCommand}" />
            </MenuItem>

            <MenuItem Header="Categories">
                <MenuItem Header="All Categories" Command="{Binding ChangeCategoryCommand}" CommandParameter="All Categories" />
                <MenuItem Header="Animals" Command="{Binding ChangeCategoryCommand}" CommandParameter="Animals" />
                <MenuItem Header="Games" Command="{Binding ChangeCategoryCommand}" CommandParameter="Games" />
                <MenuItem Header="Movies" Command="{Binding ChangeCategoryCommand}" CommandParameter="Movies" />
                <MenuItem Header="Cars" Command="{Binding ChangeCategoryCommand}" CommandParameter="Cars" />
                <MenuItem Header="Rivers" Command="{Binding ChangeCategoryCommand}" CommandParameter="Rivers" />
            </MenuItem>

            <MenuItem Header="Help">
                <MenuItem Header="About" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    BorderBrush="Black"
                    BorderThickness="2"
                    Margin="0,0,20,0"
                    Background="White">
                <Image Source="{Binding HangmanImage}"
                       Stretch="Uniform"/>
            </Border>

            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,20">

                <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Width="120"
                        Height="120"
                        Margin="0,0,20,0">
                    <Image Source="{Binding CurrentUserImage}"
                           Stretch="Uniform"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentUsername}"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding SelectedCategoryDisplay}"
                               FontSize="18"/>

                    <TextBlock Text="{Binding LevelDisplay}"
                               FontSize="18"/>

                    <TextBlock Text="{Binding TimerDisplay}"
                               FontSize="18"/>

                    <TextBlock Text="{Binding WrongGuessesDisplay}"
                               FontSize="18"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding CurrentWordDisplay}"
                           FontSize="40"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding Letters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="4" Columns="7"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Letter}"
                                    IsEnabled="{Binding IsEnabled}"
                                    Command="{Binding DataContext.GuessLetterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Letter}"
                                    Height="50"
                                    Margin="5"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Row="2"
                           Text="{Binding StatusMessage}"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,10"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>