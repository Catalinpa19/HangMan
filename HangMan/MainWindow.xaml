<Window x:Class="HangMan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HangMan - Start"
        Height="800"
        Width="1200"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Text="Choose a user"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <ListBox Grid.Row="1"
                 Grid.Column="0"
                 ItemsSource="{Binding Users}"
                 SelectedItem="{Binding SelectedUser}"
                 DisplayMemberPath="Username"
                 Margin="0,0,20,0"/>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Width="250">

            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    Width="250"
                    Height="250"
                    Background="LightGray"
                    Margin="0,0,0,15">
                <Image Source="{Binding SelectedUserImage}"
                       Stretch="Uniform"/>
            </Border>

            <TextBlock Text="{Binding SelectedUser.Username}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="New username:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>

            <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                     Height="30"
                     Margin="0,0,0,10"/>

            <Button Content="Choose Image"
                    Height="35"
                    Margin="0,0,0,8"
                    Command="{Binding ChooseImageCommand}" />

            <TextBlock Text="{Binding NewImagePath}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Margin="0,0,0,15"/>

            <Button Content="Add User"
                    Height="35"
                    Margin="0,0,0,10"
                    Command="{Binding AddUserCommand}" />

            <Button Content="Delete User"
                    Height="35"
                    Margin="0,0,0,10"
                    Command="{Binding DeleteUserCommand}" />

            <Button Content="Play"
                    Height="35"
                    Command="{Binding PlayCommand}" />
        </StackPanel>
    </Grid>
</Window>